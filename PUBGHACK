<html lang="th"><head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="https://i.postimg.cc/V6jLcF4q/IMG-0115.jpg">

<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="PUBG">
    <style>
        :root { --main: #629F9F78; --bg: #F9F9F9; --card: #E8E8E8; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            font-family: -apple-system, sans-serif;
            background-color: #020C10FA !important;
            color: #ffffff !important;
            margin: 0; padding: 0;
            overflow-x: hidden; -webkit-user-select: none;
        }

        #bg-canvas { position: fixed; inset: 0; z-index: -1; opacity: 0.5; pointer-events: none; }

        /* --- LOADER --- */
        #loader {
            position: fixed; inset: 0; background: #1704FB;
            display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 10000;
        }
        .vx-logo-frame {
            width: 100px; height: 100px; border: 4px solid var(--main);
            border-radius: 25px; overflow: hidden; display: flex;
            justify-content: center; align-items: center;
            box-shadow: 0 0 40px var(--main);
            animation: pulse 1.5s infinite; margin-bottom: 25px;
        }
        .vx-logo-frame img { width: 100%; height: 100%; object-fit: cover; }
        .progress-box { width: 70%; height: 6px; background: #0c50e2; border-radius: 10px; overflow: hidden; }
        .progress-bar { width: 0%; height: 100%; background: var(--main); box-shadow: 0 0 15px var(--main); transition: width 0.1s; }

        /* --- MAIN UI --- */
        #main-ui { display: none; padding: 20px; animation: slideIn 0.5s ease; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
        .ver-tag { background: var(--main); color: #fff; padding: 4px 12px; border-radius: 8px; font-weight: 900; font-size: 11px; box-shadow: 0 0 15px var(--main); }

        .card {
            background: #0f0f0f !important; border-radius: 20px; padding: 18px;
            margin-bottom: 15px; border: 1px solid #22c2df;
            box-shadow: 0 10px 30px rgba(26, 207, 231, 0.014);
        }
        .section-title { font-size: 12px; color: var(--main); font-weight: 900; margin-bottom: 15px; display: flex; align-items: center; letter-spacing: 1px; }
        .section-title::after { content: ""; flex: 1; height: 1px; background: linear-gradient(90deg, var(--main), transparent); margin-left: 10px; opacity: 0.3; }

        .item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #1a1a1a; }
        .item:last-child { border-bottom: none; }
        .label b { display: block; font-size: 14px; color: #eee !important; }
        .label span { font-size: 11px; color: #62bdf1 !important; }

        /* --- SWITCH --- */
        .switch { position: relative; width: 42px; height: 22px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; inset: 0; background: #29a1d8; transition: .3s; border-radius: 34px; }
        .slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background: white; transition: .3s; border-radius: 50%; }
        input:checked + .slider { background: var(--main); box-shadow: 0 0 15px var(--main); }
        input:checked + .slider:before { transform: translateX(20px); }

        /* --- GRID --- */
        .game-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .game-card { background: #151515; border-radius: 18px; padding: 15px; text-align: center; border: 1px solid #222; }
        .game-icon { width: 55px; height: 55px; border-radius: 12px; border: 1px solid var(--main); margin-bottom: 10px; object-fit: cover; }
        .btn-launch { background: var(--main); border: none; color: rgb(5, 30, 112); width: 100%; padding: 10px; border-radius: 8px; font-weight: bold; font-size: 11px; }

        #toast { position: fixed; bottom: 40px; left: 50%; transform: translateX(-50%); background: var(--main); color: white; padding: 10px 25px; border-radius: 50px; font-weight: bold; opacity: 0; transition: 0.4s; z-index: 10001; }

        @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
        @keyframes slideIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <canvas id="bg-canvas" width="1920" height="991"></canvas>
    <div id="toast">ACTIVATED!</div>

    <div id="loader" style="display: none;">
        <div class="vx-logo-frame">
            <img src="https://i.postimg.cc/02c80jbT/IMG-0164.jpg">
         </div>
        <div style="font-size:12px; color:var(--main); font-weight:bold; letter-spacing:3px; margin-bottom:15px">Hacking... </div>
        <div class="progress-box"><div class="progress-bar" id="bar" style="width: 100%;"></div></div>
        <div id="p-text" style="margin-top:10px; color:#102fe0">100%</div>
    </div>

    <div id="main-ui" style="display: block;">
        <div class="header">
            <h1 style="margin:0; font-size:24px; font-weight:900">Pxz.CN SHOP! <span style="color:var(--main)">PANEL</span></h1>
            <div class="ver-tag">main🤖📲</div>
        </div>

        <div class="card" style="border: 1px solid rgba(118, 214, 231, 0.87); background: linear-gradient(145deg, #0f0f0f, #1a0505);">
            <div class="section-title">ANTI BAN❌</div>
            <div class="item">
                <div class="label"><b>Anti-Report✅</b><span></span></div>
                <label class="switch"><input type="checkbox" onchange="showT('USE✅')"><span class="slider"></span></label>
            </div>
            <div class="item">
                <div class="label"><b>Anti-being watched✅</b><span></span></div>
                <label class="switch"><input type="checkbox" onchange="showT('USE✅')"><span class="slider"></span></label>
            </div>
            <div class="item">
                <div class="label"><b>Fix virus✅</b><span>  </span></div>
                <label class="switch"><input type="checkbox" onchange="showT('USE✅')"><span class="slider"></span></label>
            </div>
        </div>

        <div class="card">
            <div class="section-title">🥷 FILE AIMBOT🍏✅ 
                </div>
            <div class="item">
                <div class="label"><b>AIMBOT🤖📲99%</b><span>USE✅</span></div>
                <label class="switch"><input type="checkbox" onchange="showT('USE✅')"><span class="slider"></span></label>
            </div>
            <div class="item">
                <div class="label"><b>Easy head drag✅😍</b><span><ez-drag></ez-drag>(USE)</span></div>
                <label class="switch"><input type="checkbox" onchange="showT('USE✅')"><span class="slider"></span></label>
            </div>
            <div class="item">
                <div class="label"><b>DPi-SPEED TOUCH✅⚡️💨</b><span>USE✅</span></div>
                <label class="switch"><input type="checkbox" onchange="showT('USE')"><span class="slider"></span></label>
            </div>
        </div>

        <div class="card">
            <div class="section-title">BEST-FPS🍏😍</div>
            <div class="item">
                <div class="label"><b>Boost setting fps</b><span>Best frame rate</span></div>
                <label class="switch"><input type="checkbox" onchange="showT('USE✅')"><span class="slider"></span></label>
            </div>
            <div class="item">
                <div class="label"><b>Screen sensitivity X/Y✅⚡️😍</b><span>Slipped and broke my head.</span></div>
                <label class="switch"><input type="checkbox" onchange="showT('USE X/Y✅')"><span class="slider"></span></label>
            </div>
        </div>

        <div class="card">
            <div class="section-title">PUBG   OR YOU GAY</div>
            <div class="game-grid">
                <div class="game-card">
                    <img src="https://i.postimg.cc/hjdjCBHf/IMG-0163.jpg" class="game-icon">
                    <button class="btn-launch" onclick="location.href='freefire://'">PUBG MOBILE</button>
                </div>
                <div class="game-card">
                    <img src=" https://i.postimg.cc/02c80jbT/IMG-0164.jpg " class="game-icon">
                    <button class="btn-launch" onclick="location.href='YOUGAY://'">YOUGAY</button> 
                </div>
            </div>
        </div>

        <p style="text-align:center; color:#64d4e2; font-size:10px; font-weight:bold; letter-spacing:2px">Pxz.cn© 2026</p>
    </div>

    <script>
        function showT(msg) {
            const t = document.getElementById('toast');
            t.innerText = msg; t.style.opacity = '1';
            setTimeout(() => { t.style.opacity = '0'; }, 1500);
        }

        const canvas = document.getElementById('bg-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        let particles = [];
        for(let i=0; i<35; i++){ particles.push({ x: Math.random()*canvas.width, y: Math.random()*canvas.height, s: Math.random()*2, v: Math.random()*0.8 }); }
        function draw(){
            ctx.clearRect(0,0,canvas.width,canvas.height); ctx.fillStyle = '#ff0000';
            particles.forEach(p => { ctx.beginPath(); ctx.arc(p.x, p.y, p.s, 0, Math.PI*2); ctx.fill(); p.y -= p.v; if(p.y < 0) p.y = canvas.height; });
            requestAnimationFrame(draw);
        }
        draw();

        let p = 0;
        let int = setInterval(() => {
            p += Math.floor(Math.random()*8)+2;
            if(p >= 100){
                p = 100; clearInterval(int);
                setTimeout(() => {
                    document.getElementById('loader').style.display = 'none';
                    document.getElementById('main-ui').style.display = 'block';
                }, 500);
            }
            document.getElementById('bar').style.width = p+'%';
            document.getElementById('p-text').innerText = p+'%';
        }, 60);
    </script>









	
	
</body></html>




